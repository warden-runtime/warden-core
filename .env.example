# Template for your real `.env` at the repo root. Pydantic and Compose load `.env`
# (filename), not this file — copy or merge lines into `.env` for them to take effect.
# Minimal container stack: copy docker-compose.example.yml → docker-compose.yml (see docs/getting-started/installation).
# Environment variables still override values from `.env`.
#
# Do not set PATH= here if you use Docker Compose for engine/worker: it would
# override the image venv and break those containers (see docker-compose.yml).
#
# Enterprise plugins (forensic ledger, governance worker): install from the private
# warden-enterprise repo and set WARDEN_PLUGINS=enterprise.bootstrap:install.

# PostgreSQL — two related sets of variables:
#   POSTGRES_* — read by the Compose postgres service (bootstrap on first volume init)
#   DB_URL — host CLI and optional host-side migrate; use 127.0.0.1:5432 (published port)
# Defaults below work out of the box. To use your own database name, user, or password,
# change all four lines together so POSTGRES_* and DB_URL stay aligned. Compose overrides
# DB_URL inside engine/worker/migrate to postgres:5432 — do not use hostname `postgres`
# in host DB_URL.
POSTGRES_DB=engine_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
DB_URL=postgres://admin:password@127.0.0.1:5432/engine_db

# Saga step prompts: base directory for file-based prompt templates (required for reason steps).
# Engine validates at manifest registration; workers load templates at execution from the same root.
# Docker Compose sets PROMPTS_ROOT=/app/prompts and mounts ./config/prompts (see docker-compose.yml).
# Leave unset when using Compose so the service environment is not overridden by a host path.
# Host/local CLI only: PROMPTS_ROOT=./config/prompts
# PROMPTS_ROOT=

# Max JSON size for worker-commands outbox payloads (bytes). Default 262144 (256 KiB).
# OUTBOX_MAX_PAYLOAD_BYTES=262144

# Engine API (server bind)
ENGINE_API_HOST=0.0.0.0
ENGINE_API_PORT=8000

# CLI deploy: when set, CLI uses POST /v1/manifests to this URL instead of direct DB.
# ENGINE_URL=http://localhost:8000

# Messaging (topic names for outbox/consumer)
ENGINE_EVENTS_TOPIC=engine-events
WORKER_COMMANDS_TOPIC=worker-commands

# Worker: concurrent commands per process (asyncio semaphore; default 1 = serial).
# Raise only after load testing; keep below DB pool size. LLM steps are heavy.
# WORKER_MAX_IN_FLIGHT=4

# Deployment environment (e.g. development, production); used in telemetry.
ENV=development

# Optional: OTLP trace exporter (wired in setup_telemetry via Settings)
# OTLP_ENDPOINT=http://localhost:4317
# OTLP_INSECURE=true

# Root JSON log level for engine/worker (INFO | DEBUG | …)
# LOGGING_LEVEL=INFO

# Provider API keys (set in real .env)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub MCP demo — worker spawns github-mcp-server via Docker socket (see config/worker.github-demo.yaml)
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Hosted SSE MCP — referenced from worker manifest headers (Bearer ${ENV:COMPANY_MCP_TOKEN})
# Set on the worker service only; do not commit real tokens.
# COMPANY_MCP_TOKEN=
# GATEWAY_KEY=

# Local / sovereign LLM (worker manifest provider: local; OpenAI-compatible API)
# No API key required — Warden waives credentials for provider: local and provider: mock.
# Compose: worker runs in a container; Ollama runs on the host. Set the URL below and ensure
# docker-compose.yml has extra_hosts (host.docker.internal:host-gateway) on the worker service.
# Ollama must listen beyond 127.0.0.1 — see docs/getting-started/configuration.md#local-llm-under-docker-ollama.
# WARDEN_LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
# Defaults to http://localhost:11434/v1 when unset (bare-metal / host-network worker).

# LLM retry (worker; honors Retry-After / "try again in Xs", then jitter; cap = MAX_DELAY)
# WARDEN_LLM_RETRY_ENABLED=true
# WARDEN_LLM_RETRY_MAX_ATTEMPTS=3
# WARDEN_LLM_RETRY_BASE_DELAY_S=1.0
# WARDEN_LLM_RETRY_MAX_DELAY_S=60.0

# ReAct loop: max chars for tool-role ChatMessage content sent to the LLM (facts use full payload).
# Set to 0 to disable clipping (debug). Default 8000.
# WARDEN_REACT_TOOL_MESSAGE_LIMIT=8000

# Optional process-wide fallback for reason-step max_step_tokens when the saga YAML omits it.
# Counts gross provider total_tokens (prompt + completion). 0 or unset = no fallback.
# WARDEN_MAX_STEP_TOKENS=0

# Stuck-saga recovery: stale worker claims and outbox IN_PROGRESS rows (defaults: 1800s / 60s / batch 20)
# WORKER_STALE_CLAIM_SECONDS=1800
# WORKER_CLAIM_REAP_INTERVAL_SECONDS=60
# OUTBOX_STALE_IN_PROGRESS_SECONDS=1800
# OUTBOX_REAP_INTERVAL_SECONDS=60
# OUTBOX_REAP_BATCH_SIZE=20

